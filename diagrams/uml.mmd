classDiagram
    %% PawPal+ final class diagram -- matches pawpal_system.py

    class Task {
        +str description
        +str time
        +str frequency
        +bool completed
        +date due_date
        +update(description, time, frequency) None
        +mark_complete() None
        +mark_incomplete() None
        +next_occurrence() Task
    }

    class Pet {
        +str name
        +str species
        +int age
        +str special_needs
        +list~Task~ tasks
        +add_task(task) None
        +remove_task(task) None
        +get_tasks() list~Task~
    }

    class Owner {
        +str name
        +dict preferences
        +list~Pet~ pets
        +add_pet(pet) None
        +get_all_tasks() list~Task~
        +get_all_tasks_with_pet() list
    }

    class Scheduler {
        +Owner owner
        +get_all_tasks() list~Task~
        +pending_tasks() list~Task~
        +completed_tasks() list~Task~
        +tasks_by_frequency(frequency) list~Task~
        +sort_by_time() list~Task~
        +daily_plan() list~Task~
        +complete_task(task) Task
        +detect_conflicts() list~str~
        +filter_tasks(completed, pet_name) list
    }

    %% Structure: who owns/holds what
    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has

    %% Collaboration: how the Scheduler works and how recurrence spawns tasks
    Scheduler ..> Owner : retrieves tasks from
    Scheduler ..> Task : creates next occurrence (complete_task)
    Task ..> Task : next_occurrence() spawns a copy
